{
    "project": "enduro",
    "bins": [
        {
            "name": "golangci-lint",
            "url": "https://github.com/golangci/golangci-lint",
            "version": "2.11.4",
            "asset_pattern": "{name}-{version}-{goos}-{goarch}.tar.gz"
        },
        {
            "name": "goreleaser",
            "url": "https://github.com/goreleaser/goreleaser",
            "version": "2.15.2",
            "asset_pattern": "{name}_{os}_{arch}.tar.gz"
        },
        {
            "name": "go-mod-outdated",
            "url": "https://github.com/psampaz/go-mod-outdated",
            "version": "0.9.0",
            "asset_pattern": "{name}_{version}_{os}_{arch}.tar.gz"
        },
        {
            "name": "gotestsum",
            "url": "https://github.com/gotestyourself/gotestsum",
            "version": "1.13.0",
            "asset_pattern": "{name}_{version}_{goos}_{goarch}.tar.gz"
        },
        {
            "name": "goa",
            "go_package": "goa.design/goa/v3/cmd/goa",
            "version": "3.25.3"
        },
        {
            "name": "mockgen",
            "go_package": "go.uber.org/mock/mockgen",
            "version": "0.6.0"
        },
        {
            "name": "temporal-cli",
            "url": "https://github.com/temporalio/cli",
            "version": "1.6.2",
            "asset_pattern": "temporal_cli_{version}_{goos}_{goarch}.tar.gz"
        },
        {
            "name": "jq",
            "url": "https://github.com/jqlang/jq",
            "version": "1.8.1",
            "asset_pattern": "{name}-{goos}-{goarch}",
            "tag_pattern": "{name}-{version}",
            "modifiers": {
                "goos": {
                    "darwin": "macos"
                }
            }
        },
    ]
}
